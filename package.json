{
  "name": "vscode-voice-assistant",
  "displayName": "VS Code Voice Assistant",
  "description": "A local voice-to-text assistant for VS Code powered by whisper.cpp.",
  "version": "0.1.1",
  "publisher": "iftekharpriyo",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IftekharPriyo/vscode-voice-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/IftekharPriyo/vscode-voice-assistant/issues"
  },
  "homepage": "https://github.com/IftekharPriyo/vscode-voice-assistant#readme",
  "keywords": [
    "voice",
    "speech-to-text",
    "transcription",
    "whisper",
    "assistant"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.96.2"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "voiceAssistantSecondaryViewContainer",
          "title": "Voice Assistant",
          "icon": "resources/microphone.svg"
        }
      ]
    },
    "views": {
      "voiceAssistantSecondaryViewContainer": [
        {
          "type": "webview",
          "id": "voiceAssistant.view",
          "name": "Voice Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "voiceAssistant.openPanel",
        "title": "Voice Assistant: Open Panel"
      },
      {
        "command": "voiceAssistant.startRecording",
        "title": "Voice Assistant: Start Recording",
        "icon": "$(mic)"
      },
      {
        "command": "voiceAssistant.stopRecording",
        "title": "Voice Assistant: Stop Recording",
        "icon": "$(debug-stop)"
      },
      {
        "command": "voiceAssistant.resetTranscript",
        "title": "Voice Assistant: Reset Transcript",
        "icon": "$(clear-all)"
      },
      {
        "command": "voiceAssistant.copyTranscript",
        "title": "Voice Assistant: Copy Transcript",
        "icon": "$(copy)"
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package:marketplace": "npx @vscode/vsce package --readme-path MARKETPLACE.md"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.96.2",
    "typescript": "^5.9.3"
  }
}
